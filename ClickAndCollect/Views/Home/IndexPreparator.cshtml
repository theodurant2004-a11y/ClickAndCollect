@model List<ClickAndCollect.Models.Order>

@{
    ViewData["Title"] = "Orders to Prepare";
}

<div class="container mt-4">
    <h2>Orders to Prepare</h2>
    <hr />

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }
    @if (ViewBag.ErrorMessage != null)
    {
        <div class="alert alert-danger">
            <h4>Database Error</h4>
            <p>[ERROR]: @ViewBag.ErrorMessage</p>
        </div>
    }
    @if (ViewBag.InfoMessage != null)
    {
        <div class="alert alert-info text-center">
            @ViewBag.InfoMessage
        </div>
    }
    else if (Model != null && Model.Count > 0)
    {
        <table class="table table-striped table-hover mt-3">
            <thead class="table-dark">
                <tr>
                    <th>Client</th>
                    <th>Time Slot</th>
                    <th>Status</th>
                    <th class="text-center">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    <tr class="@(order.Status == "Prepared" ? "table-success" : "")">
                        <td class="align-middle">
                            @order.Client.FirstName @order.Client.SurName
                        </td>
                        <td class="align-middle">
                            @order.TimeSlot.StartingHour.ToString("HH:mm") - @order.TimeSlot.EndingHour.ToString("HH:mm")
                        </td>
                        <td class="align-middle">@order.Status</td>
                        <td class="text-center align-middle">
                            @if (order.Status == "Prepared")
                            {
                                <span class="badge bg-success">Ready</span>
                            }
                            else
                            {
                                <a asp-action="PrepareOrder" asp-route-orderId="@order.OrderID"
                                   class="btn btn-primary btn-sm">
                                    Prepare
                                </a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
