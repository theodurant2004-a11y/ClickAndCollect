@model Client
@{
    ViewData["Title"] = "Edit Profile";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">

            <div class="card border-0 shadow-sm rounded-4 p-4">

                <div class="d-flex align-items-center gap-3 mb-4">
                    <div class="rounded-circle d-flex align-items-center justify-content-center text-white fw-bold fs-3"
                         style="width: 70px; height: 70px; background-color: #1a4a52;">
                        @Model.FirstName?[0]@Model.SurName?[0]
                    </div>
                    <div>
                        <h4 class="fw-bold mb-0">@Model.FirstName @Model.SurName</h4>
                        <p class="text-muted small mb-0">@Model.Email</p>
                    </div>
                </div>

                <hr />

                <form method="post">

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="FirstName" class="text-muted small mb-1"></label>
                            <input asp-for="FirstName" class="form-control rounded-pill border-dark" />
                            <span asp-validation-for="FirstName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="SurName" class="text-muted small mb-1"></label>
                            <input asp-for="SurName" class="form-control rounded-pill border-dark" />
                            <span asp-validation-for="SurName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Email" class="text-muted small mb-1"></label>
                            <input asp-for="Email" class="form-control rounded-pill border-secondary"
                                   disabled />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Phone" class="text-muted small mb-1"></label>
                            <input asp-for="Phone" class="form-control rounded-pill border-dark" />
                            <span asp-validation-for="Phone" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="RoadName" class="text-muted small mb-1"></label>
                            <input asp-for="RoadName" class="form-control rounded-pill border-dark" />
                            <span asp-validation-for="RoadName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="RoadNumber" class="text-muted small mb-1"></label>
                            <input asp-for="RoadNumber" class="form-control rounded-pill border-dark" />
                            <span asp-validation-for="RoadNumber" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="City" class="text-muted small mb-1"></label>
                            <input asp-for="City" class="form-control rounded-pill border-dark" />
                            <span asp-validation-for="City" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="PostalCode" class="text-muted small mb-1"></label>
                            <input asp-for="PostalCode" class="form-control rounded-pill border-dark" />
                            <span asp-validation-for="PostalCode" class="text-danger small"></span>
                        </div>
                    </div>

                    <hr />

                    <div class="d-flex gap-2 mt-2">
                        <input type="submit" class="btn text-white rounded-pill px-4"
                               style="background-color: #00bcd4;" />

                        <a asp-action="Profile" asp-controller="Home"
                           class="btn btn-outline-secondary rounded-pill px-4">
                            Cancel
                        </a>
                    </div>

                </form>

            </div>
        </div>
    </div>
</div>