@model List<Article>
@{
    ViewData["Title"] = "Catalog";
    List<Category> categories = ViewBag.Categories as List<Category>;
    string? selectedCategory = Context.Request.Query["category"];
    selectedCategory = string.IsNullOrEmpty(selectedCategory) ? null : selectedCategory;
}

<h1 class="catalog-title mb-4">Product List</h1>

<div class="catalog-container">

    <div class="filter-sidebar">
        <h5 class="sidebar-title">Refine your search</h5>

        <form method="get" asp-action="Index">
            <p class="filter-group-title">Categories</p>

            <div class="form-check custom-filter-radio mb-2">
                <input class="form-check-input" type="radio" name="category" value="" id="cat_all"
                       @(selectedCategory == null ? "checked" : "") />
                <label class="form-check-label fst-italic" for="cat_all">All</label>
            </div>

            <div class="row g-0">
                <div class="col-6">
                    @for (int i = 0; i < categories.Count; i += 2)
                    {
                        <div class="form-check custom-filter-radio mb-2">
                            <input class="form-check-input" type="radio" name="category" value="@categories[i]" id="cat_@categories[i]"
                                   @(selectedCategory == categories[i] ? "checked" : "") />
                            <label class="form-check-label fst-italic" for="cat_@categories[i]">@categories[i]</label>
                        </div>
                    }
                </div>

                <div class="col-6">
                    @for (int i = 1; i < categories.Count; i += 2)
                    {
                        <div class="form-check custom-filter-radio mb-2">
                            <input class="form-check-input" type="radio" name="category" value="@categories[i]" id="cat_@categories[i]"
                                   @(selectedCategory == categories[i] ? "checked" : "") />
                            <label class="form-check-label fst-italic" for="cat_@categories[i]">@categories[i]</label>
                        </div>
                    }
                </div>
            </div>

            <button type="submit" class="btn btn-filter w-100 mt-3">
                Filter
            </button>
        </form>
    </div>

    <div class="products-display-zone">
        @if (Model.Count == 0)
        {
            <div class="text-center py-5 no-products-box">
                <h4 class="fw-bold">No products found</h4>
                <p class="text-muted">No products match your search. Try again later.</p>
            </div>
        }
        else
        {
            <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-4">
                @foreach (Article article in Model)
                {
                    <div class="col">
                        <partial name="_ViewArticle" model="article" />
                    </div>
                }
            </div>
        }
    </div>

</div>