@model List<Article>
@{
    ViewData["Title"] = "Catalog";
    List<Category> categories = ViewBag.Categories as List<Category>;
    string? selectedCategory = Context.Request.Query["category"];
    selectedCategory = string.IsNullOrEmpty(selectedCategory) ? null : selectedCategory;
}

@if (TempData["Success"] != null)
{
    <div class="position-fixed top-0 end-0 p-3" style="z-index: 9999;">
        <div class="toast show align-items-center text-white border-0 toast-success">
            <div class="d-flex">
                <div class="toast-body fw-semibold">
                    @TempData["Success"]
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto"
                        data-bs-dismiss="toast"></button>
            </div>
        </div>
    </div>
}

<h1 class="mb-4">Product List</h1>

<div class="d-flex flex-column flex-md-row">
    <div class="p-3 rounded-3 me-3 filter-panel">
        <h5 class="fw-bold mb-3">Refine your search</h5>
        <form method="get" asp-action="Index">
            <p class="fw-bold mb-2">Categories</p>
            <div class="form-check mb-2">
                <input class="form-check-input" type="radio" name="category" value=""
                       @(selectedCategory == null ? "checked" : "") />
                <label class="form-check-label fst-italic">All</label>
            </div>
            <div class="row">
                <div class="col-6">
                    @for (int i = 0; i < categories.Count; i += 2)
                    {
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="radio" name="category"
                                   value="@categories[i]" id="cat_@categories[i]"
                                   @(selectedCategory == categories[i].Name ? "checked" : "") />
                            <label class="form-check-label fst-italic" for="cat_@categories[i]">
                                @categories[i]
                            </label>
                        </div>
                    }
                </div>
                <div class="col-6">
                    @for (int i = 1; i < categories.Count; i += 2)
                    {
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="radio" name="category"
                                   value="@categories[i]" id="cat_@categories[i]"
                                   @(selectedCategory == categories[i].Name ? "checked" : "") />
                            <label class="form-check-label fst-italic" for="cat_@categories[i]">
                                @categories[i]
                            </label>
                        </div>
                    }
                </div>
            </div>
            <button type="submit" class="btn btn-sm btn-filter mt-3 w-100">
                Filter
            </button>
        </form>
    </div>

    <div style="width: 75%;">
        @if (Model.Count == 0)
        {
            <div class="text-center py-5">
                <h4 class="fw-bold">No products found</h4>
                <p class="text-muted">No products match your search. Try again later.</p>
            </div>
        }
        <div class="row row-cols-1 row-cols-sm-1 row-cols-md-3 g-4">
            @foreach (Article article in Model)
            {
                <div class="col">
                    <partial name="_ViewArticle" model="article" />
                </div>
            }
        </div>
    </div>
</div>