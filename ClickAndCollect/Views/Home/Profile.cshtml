@model Client
@{
    ViewData["Title"] = "My Profile";
}

<div class="profile-container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">

            <div class="profile-card card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="profile-header-bg"></div>

                <div class="card-body px-5 pb-5 position-relative">

                    <div class="profile-avatar shadow-sm">
                        @Model.FirstName?[0]@Model.SurName?[0]
                    </div>

                    <div class="profile-title mt-3 mb-4">
                        <h3 class="fw-bold text-dark mb-1">@Model.FirstName @Model.SurName</h3>
                        <p class="text-muted"><i class="bi bi-envelope-fill me-2 text-teal opacity-75"></i>@Model.Email</p>
                    </div>

                    <hr class="mb-4 border-secondary opacity-10" />

                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="info-box p-3 rounded-4">
                                <p class="text-muted small mb-1"><i class="bi bi-person me-2"></i>First Name</p>
                                <p class="fw-semibold mb-0 fs-5 text-dark">@Model.FirstName</p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="info-box p-3 rounded-4">
                                <p class="text-muted small mb-1"><i class="bi bi-person-badge me-2"></i>Surname</p>
                                <p class="fw-semibold mb-0 fs-5 text-dark">@Model.SurName</p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="info-box p-3 rounded-4">
                                <p class="text-muted small mb-1"><i class="bi bi-envelope-at me-2"></i>Email Address</p>
                                <p class="fw-semibold mb-0 fs-5 text-dark">@Model.Email</p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="info-box p-3 rounded-4">
                                <p class="text-muted small mb-1"><i class="bi bi-telephone me-2"></i>Phone Number</p>
                                <p class="fw-semibold mb-0 fs-5 text-dark">@Model.Phone</p>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="info-box p-3 rounded-4">
                                <p class="text-muted small mb-1"><i class="bi bi-geo-alt me-2"></i>Address</p>
                                <p class="fw-semibold mb-0 fs-5 text-dark">@Model.RoadName @Model.RoadNumber, @Model.PostalCode @Model.City</p>
                            </div>
                        </div>
                    </div>

                    <hr class="my-4 border-secondary opacity-10" />

                    <div class="d-flex gap-3 mt-2">
                        <a asp-action="EditProfile" asp-controller="Home" class="btn btn-primary-teal rounded-pill px-4 py-2 d-inline-flex align-items-center fw-bold shadow-sm">
                            <i class="bi bi-pencil-square me-2"></i> Edit Profile
                        </a>

                        <a asp-action="Logout" asp-controller="Home" class="btn btn-outline-danger rounded-pill px-4 py-2 d-inline-flex align-items-center">
                            <i class="bi bi-box-arrow-right me-2"></i> Logout
                        </a> 

                    </div>

                </div>
            </div>

        </div>
    </div>
</div>