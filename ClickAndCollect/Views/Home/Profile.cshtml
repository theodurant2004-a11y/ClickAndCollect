@model Client
@{
    ViewData["Title"] = "My Profile";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">

            <div class="card border-0 shadow-sm rounded-4 p-4">

                <div class="d-flex align-items-center gap-3 mb-4">
                    <div class="rounded-circle d-flex align-items-center justify-content-center text-white fw-bold fs-3"
                         style="width: 70px; height: 70px; background-color: #1a4a52;">
                        @Model.FirstName?[0]@Model.SurName?[0]
                    </div>
                    <div>
                        <h4 class="fw-bold mb-0">@Model.FirstName @Model.SurName</h4>
                        <p class="text-muted small mb-0">@Model.Email</p>
                    </div>
                </div>

                <hr />

                <div class="row g-3">
                    <div class="col-md-6">
                        <p class="text-muted small mb-1">First Name</p>
                        <p class="fw-semibold">@Model.FirstName</p>
                    </div>
                    <div class="col-md-6">
                        <p class="text-muted small mb-1">Surname</p>
                        <p class="fw-semibold">@Model.SurName</p>
                    </div>
                    <div class="col-md-6">
                        <p class="text-muted small mb-1">Email Address</p>
                        <p class="fw-semibold">@Model.Email</p>
                    </div>
                    <div class="col-md-6">
                        <p class="text-muted small mb-1">Phone Number</p>
                        <p class="fw-semibold">@Model.Phone</p>
                    </div>
                    <div class="col-12">
                        <p class="text-muted small mb-1">Address</p>
                        <p class="fw-semibold">@Model.RoadName @Model.RoadNumber, @Model.PostalCode @Model.City</p>
                    </div>
                </div>

                <hr />

                <div class="d-flex gap-2 mt-2">
                    <a asp-action="EditProfile" asp-controller="Home"
                       class="btn text-white rounded-pill px-4"
                       style="background-color: #00bcd4;">
                        Edit Profile
                    </a>
                    @* <a asp-action="Logout" asp-controller="Home"
                       class="btn btn-outline-danger rounded-pill px-4">
                        Logout
                    </a> *@
                </div>

            </div>
        </div>
    </div>
</div>