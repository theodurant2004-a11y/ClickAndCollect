@{
    ViewData["Title"] = "Connexion";
}

<div class="min-vh-100 d-flex align-items-center justify-content-center">
    <div class="rounded-4 shadow-lg p-5" style="width: 100%; max-width: 500px; background-color: white;">

        <h3 class="fw-bold text-center mb-1">Connexion</h3>
        <p class="text-muted text-center small mb-4">Content de vous revoir !</p>


        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger small py-2 text-center">
                @ViewBag.Error
            </div>
        }

        <form method="post" asp-action="Connexion" asp-controller="Home">

            <div class="mb-3">
                <label for="email" class="form-label fw-semibold">Email</label>
                <input type="email" name="email" id="email" class="form-control rounded-pill border-dark"
                       placeholder="john.doe@example.com" required />
            </div>

            <div class="mb-4">
                <label for="password" class="form-label fw-semibold">Password</label>
                <input type="password" name="password" id="password" class="form-control rounded-pill border-dark" required />
            </div>

            <button type="submit" class="btn w-100 fw-bold rounded-pill mb-3"
                    style="background-color: #e8d44d;">
                Connexion
            </button>

            <p class="text-center small text-muted">
                Doesn't have an account ?
                <a asp-action="SignUp" asp-controller="Home" class="fst-italic text-dark fw-bold">Sign Up</a>
            </p>
        </form>

    </div>
</div>