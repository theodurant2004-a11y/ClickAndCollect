@model ClickAndCollect.Models.Order

@{
    ViewData["Title"] = "Finalisation de la Commande";
}

<div class="container mt-4">
    <h2>Détails de la Commande N° @Model.OrderID</h2>
    <p><strong>Client :</strong> @Model.Client.FirstName @Model.Client.SurName</p>
    <hr />

    <div class="row">
        <div class="col-md-8">
            <h4>Articles commandés</h4>
            @if (Model.OrderLines == null || Model.OrderLines.Count == 0)
            {
                <div class="alert alert-warning">Cette commande ne contient plus aucun article.</div>
            }
            else
            {
                <table class="table table-bordered align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>Article</th>
                            <th>Prix Unitaire</th>
                            <th class="text-center">Quantité</th>
                            <th class="text-center">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var line in Model.OrderLines)
                        {
                            <tr>
                                <td>@line.Article_.NameProduct</td>
                                <td>@line.Article_.Price.ToString("F2") €</td>
                                <td class="text-center"><strong>@line.Quantity</strong></td>
                                <td class="text-center">
                                    <form asp-action="RemoveItemFromOrder" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="itemId" value="@line.Article_.IDArticle" />
                                        <button type="submit" class="btn btn-danger btn-sm" title="Retirer 1 exemplaire">
                                            <i class="bi bi-trash"></i> Retirer 1
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>

        <div class="col-md-4">
            <div class="card mb-3">
                <div class="card-header bg-primary text-white">Gestion des Boîtes Retournées</div>
                <div class="card-body">
                    <form asp-action="ManageBoxReturn" method="post">
                        @Html.AntiForgeryToken()
                        <p><small>Boîtes fournies au client : @Model.BoxUsed</small></p>
                        <div class="mb-3">
                            <label class="form-label">Nombre de boîtes ramenées :</label>
                            <input type="number" name="returnedBoxes" value="@Model.BoxReturned" class="form-control" min="0" required />
                        <button type="submit" class="btn btn-primary w-100">Mettre à jour les boîtes</button>
                    </form>
                </div>
            </div>

            <div class="card">
                <div class="card-header bg-dark text-white">Résumé du Paiement</div>
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-2">
                        <span>Frais de service :</span>
                        <span>@Model.ServiceCharge.ToString("F2") €</span>
                    </div>
                    <hr />
                    <div class="d-flex justify-content-between">
                        <strong>Total à payer :</strong>
                        <strong class="text-success fs-5">@Model.GetTotalPrice().ToString("F2") €</strong>
                    </div>
                </div>
            </div>

            <div class="mt-4 d-flex gap-2">
                <form asp-action="CancelFinalizeOrder" method="post" class="w-50">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-secondary w-100">Annuler / Retour</button>
                </form>

                <a asp-action="IndexCashier" class="btn btn-success w-50">Valider & Délivrer</a>
            </div>
        </div>
    </div>
</div>