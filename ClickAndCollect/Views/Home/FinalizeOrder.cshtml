@model ClickAndCollect.Models.Order

@{
    ViewData["Title"] = "Finalize Order";
    decimal boxDeposit = Model.BoxUsed * 5.95m;
    decimal boxRefund = Model.BoxReturned * 5.95m;
}

<div class="container mt-4">
    <h2>Order Details N° @Model.OrderID</h2>
    <p><strong>Client:</strong> @Model.Client.FirstName @Model.Client.SurName</p>
    <hr />

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="row">

        <!-- Article list -->
        <div class="col-md-7">
            <h4>Ordered Articles</h4>
            @if (Model.OrderLines == null || Model.OrderLines.Count == 0)
            {
                <div class="alert alert-warning">This order contains no articles.</div>
            }
            else
            {
                <table class="table table-bordered align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>Article</th>
                            <th>Unit Price</th>
                            <th class="text-center">Qty</th>
                            <th class="text-center">Subtotal</th>
                            <th class="text-center">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var line in Model.OrderLines)
                        {
                            <tr>
                                <td>@line.Article_.NameProduct</td>
                                <td>@line.Article_.Price.ToString("F2") €</td>
                                <td class="text-center"><strong>@line.Quantity</strong></td>
                                <td class="text-center">@line.GetPriceLine().ToString("F2") €</td>
                                <td class="text-center">
                                    <form asp-action="RemoveItemFromOrder" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="orderId" value="@Model.OrderID" />
                                        <input type="hidden" name="articleId" value="@line.Article_.IDArticle" />
                                        <button type="submit" class="btn btn-danger btn-sm">
                                            <i class="bi bi-trash"></i> Remove 1
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>

        <div class="col-md-5">

            <!-- Box management -->
            <div class="card mb-3">
                <div class="card-header bg-primary text-white">Box Management</div>
                <div class="card-body">
                    <form asp-action="UpdateBoxes" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="orderId" value="@Model.OrderID" />
                        <div class="mb-3">
                            <label class="form-label">Boxes given to client:</label>
                            <input type="number" name="boxUsed" value="@Model.BoxUsed"
                                   class="form-control" min="0" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Boxes returned by client:</label>
                            <input type="number" name="boxReturned" value="@Model.BoxReturned"
                                   class="form-control" min="0" required />
                        </div>
                        <button type="submit" class="btn btn-primary w-100">Update Boxes</button>
                    </form>
                </div>
            </div>

            <!-- Payment summary -->
            <div class="card mb-3">
                <div class="card-header bg-dark text-white">Payment Summary</div>
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-1">
                        <span>Articles:</span>
                        <span>@Model.GetArticlesTotal().ToString("F2") €</span>
                    </div>
                    <div class="d-flex justify-content-between mb-1">
                        <span>Service charge:</span>
                        <span>@Model.ServiceCharge.ToString("F2") €</span>
                    </div>
                    <div class="d-flex justify-content-between mb-1">
                        <span>Box deposit (@Model.BoxUsed × 5.95 €):</span>
                        <span>+ @boxDeposit.ToString("F2") €</span>
                    </div>
                    @if (Model.BoxReturned > 0)
                    {
                        <div class="d-flex justify-content-between mb-1 text-success">
                            <span>Box refund (@Model.BoxReturned × 5.95 €):</span>
                            <span>- @boxRefund.ToString("F2") €</span>
                        </div>
                    }
                    <hr />
                    <div class="d-flex justify-content-between">
                        <strong>Total to pay:</strong>
                        <strong class="text-success fs-5">@Model.GetTotalPrice().ToString("F2") €</strong>
                    </div>
                </div>
            </div>

            <!-- Actions -->
            <div class="d-flex gap-2">
                <form asp-action="CancelFinalizeOrder" method="post" class="w-50">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="orderId" value="@Model.OrderID" />
                    <button type="submit" class="btn btn-secondary w-100">Cancel</button>
                </form>

                <form asp-action="CloseFinalizeOrder" method="post" class="w-50">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="orderId" value="@Model.OrderID" />
                    <input type="hidden" name="boxUsed" value="@Model.BoxUsed" />
                    <input type="hidden" name="boxReturned" value="@Model.BoxReturned" />
                    <button type="submit" class="btn btn-success w-100">Validate & Deliver</button>
                </form>
            </div>

        </div>
    </div>
</div>
