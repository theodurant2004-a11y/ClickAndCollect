@model ClickAndCollect.Models.Order
@using ClickAndCollect.Models
@{
    ViewData["Title"] = "Checkout";
    List<Store> stores = ViewBag.Stores as List<Store>;
    List<TimeSlot> timeSlots = ViewBag.TimeSlots as List<TimeSlot>;
    List<DateTime> availableDates = ViewBag.AvailableDates as List<DateTime>;
    int? selectedStoreId = ViewBag.SelectedStoreId;
    string selectedTimeSlotInfo = ViewBag.SelectedTimeSlotInfo as string;
    string selectedDate = ViewBag.SelectedDate as string;
}

<div class="checkout-container">

    <h1 class="checkout-title">Checkout</h1>

    <div class="checkout-layout">

        <!-- Steps -->
        <div class="checkout-steps">

            <!-- Store -->
            <div class="checkout-card">
                <div class="checkout-step-header">
                    <span class="step-number">1</span>
                    <h5 class="step-title">Choose a store</h5>
                </div>
                <form asp-action="Checkout" asp-controller="Home" method="get">
                    @foreach (Store store in stores)
                    {
                        <div class="checkout-radio-item">
                            <input class="checkout-radio-input" type="radio" name="storeId"
                                   value="@store.Id" id="store_@store.Id"
                                   @(selectedStoreId == store.Id ? "checked" : "") />
                            <label class="checkout-radio-label" for="store_@store.Id">
                                <span class="store-name">@store.Name</span>
                                <span class="store-address">@store.RoadName @store.RoadNumber, @store.PostalCode @store.City</span>
                            </label>
                        </div>
                    }
                    <button type="submit" class="btn-checkout-action mt-3">
                        Confirm store →
                    </button>
                </form>
            </div>

            <!-- Date -->
            @if (selectedStoreId != null && availableDates != null)
            {
                <div class="checkout-card">
                    <div class="checkout-step-header">
                        <span class="step-number">2</span>
                        <h5 class="step-title">Choose a date</h5>
                    </div>
                    <form asp-action="Checkout" asp-controller="Home" method="get">
                        <input type="hidden" name="storeId" value="@selectedStoreId" />
                        <div class="dates-grid">
                            @foreach (DateTime date in availableDates)
                            {
                                <div class="checkout-radio-item">
                                    <input class="checkout-radio-input" type="radio" name="selectedDate"
                                           value="@date.ToString("yyyy-MM-dd")" id="date_@date.ToString("yyyyMMdd")"
                                           @(selectedDate == date.ToString("yyyy-MM-dd") ? "checked" : "") />
                                    <label class="checkout-radio-label" for="date_@date.ToString("yyyyMMdd")">
                                        @date.ToString("dddd dd/MM/yyyy")
                                    </label>
                                </div>
                            }
                        </div>
                        <button type="submit" class="btn-checkout-action mt-3">
                            Confirm date →
                        </button>
                    </form>
                </div>
            }

            <!-- Time slot -->
            @if (selectedStoreId != null && selectedDate != null && timeSlots != null)
            {
                List<TimeSlot> slotsForDate = new List<TimeSlot>();
                foreach (TimeSlot slot in timeSlots)
                {
                    if (slot.Date.ToString("yyyy-MM-dd") == selectedDate)
                        slotsForDate.Add(slot);
                }

                <div class="checkout-card">
                    <div class="checkout-step-header">
                        <span class="step-number">3</span>
                        <h5 class="step-title">Choose a time slot</h5>
                    </div>
                    @if (!slotsForDate.Any())
                    {
                        <p class="text-muted">No available time slots for this date.</p>
                    }
                    else
                    {
                        <form asp-action="Checkout" asp-controller="Home" method="get">
                            <input type="hidden" name="storeId" value="@selectedStoreId" />
                            <input type="hidden" name="selectedDate" value="@selectedDate" />
                            <div class="timeslots-grid">
                                @foreach (TimeSlot slot in slotsForDate)
                                {
                                    string slotInfo = slot.Id + "|" + slot.StartingHour.ToString("HH:mm") + "|" + slot.EndingHour.ToString("HH:mm");
                                    <div class="timeslot-item @(slot.IsFull ? "timeslot-full" : "")">
                                        <input class="checkout-radio-input" type="radio" name="timeSlotInfo"
                                               value="@slotInfo" id="slot_@slot.StartingHour.Hour"
                                               @(selectedTimeSlotInfo == slotInfo ? "checked" : "")
                                               @(slot.IsFull ? "disabled" : "") />
                                        <label class="timeslot-label" for="slot_@slot.StartingHour.Hour">
                                            @slot.StartingHour.ToString("HH:mm") - @slot.EndingHour.ToString("HH:mm")
                                            @if (slot.IsFull)
                                            {
                                                <span class="timeslot-full-badge">Full</span>
                                            }
                                        </label>
                                    </div>
                                }
                            </div>
                            <button type="submit" class="btn-checkout-action mt-3">
                                Confirm time slot →
                            </button>
                        </form>
                    }
                </div>
            }

            <!-- Place order -->
            @if (selectedStoreId != null && selectedDate != null && selectedTimeSlotInfo != null)
            {
                <div class="checkout-card checkout-card--highlight">
                    <div class="checkout-step-header">
                        <span class="step-number step-number--yellow">4</span>
                        <h5 class="step-title">Confirm your order</h5>
                    </div>
                    <p class="text-muted small mb-3">Everything looks good? Place your order!</p>
                    <form asp-action="PlaceOrder" asp-controller="Home" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="storeId" value="@selectedStoreId" />
                        <input type="hidden" name="timeSlotInfo" value="@selectedTimeSlotInfo" />
                        <input type="hidden" name="selectedDate" value="@selectedDate" />
                        <button type="submit" class="btn-place-order w-100">
                            Place order
                        </button>
                    </form>
                </div>
            }

        </div>

        <!--  Order summary -->
        <div class="checkout-summary">
            <div class="checkout-card">
                <h5 class="step-title mb-3">Order Summary</h5>
                @foreach (OrderLine line in Model.OrderLines)
                {
                    <div class="summary-line">
                        <span>@line.Article_.NameProduct x @line.Quantity</span>
                        <span>€@line.GetPriceLine().ToString("0.00")</span>
                    </div>
                }
                <hr class="summary-divider" />
                <div class="summary-line summary-line--muted">
                    <span>Service charge</span>
                    <span>€5.95</span>
                </div>
                <hr class="summary-divider" />
                <div class="summary-line summary-line--total">
                    <span>Total</span>
                    <span>€@((Model.GetArticlesTotal() + 5.95m).ToString("0.00"))</span>
                </div>
                <a asp-action="ShoppingCart" asp-controller="Home"
                   class="btn-back-cart w-100 mt-3 d-block text-center">
                    ← Back to cart
                </a>
            </div>
        </div>

    </div>
</div>