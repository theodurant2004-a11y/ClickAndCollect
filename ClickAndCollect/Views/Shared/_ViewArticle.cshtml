@model Article
<div class="card h-100 border-0 shadow-sm rounded-4">
    <img src="@Model.ImagePath"
         class="card-img-top rounded-top-4 card-img-article"
         alt="@Model.NameProduct">
    <div class="card-body d-flex flex-column px-3 pb-1">
        <h5 class="card-title fw-bold mb-0">@Model.NameProduct</h5>
        <p class="text-muted fst-italic small mb-1">@Model.Category</p>
        <p class="fw-bold fs-5 mb-2">@Model.Price.ToString("C")</p>
        <a asp-action="AddToCart" asp-controller="Home"
           asp-route-_articleId="@Model.IDArticle"
           asp-route-_quantity="1"
           asp-route-category="@Context.Request.Query["category"]"
           class="btn btn-sm w-100 mb-1 btn-add-to-cart fw-semibold">
            Add to cart
        </a>
        <a href="#" class="text-center text-muted small mb-1">View product</a>
    </div>
</div>