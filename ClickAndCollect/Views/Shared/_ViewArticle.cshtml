@model ClickAndCollect.Models.Article

<div class="product-card">
    <div class="product-img-wrapper">
        @if (Model.ImagePath != null && Model.ImagePath != "none")
        {
            <img src="@Model.ImagePath"
                 alt="@Model.NameProduct"
                 class="product-img"
                 onerror="this.parentElement.innerHTML='<div class=\'product-img-placeholder\'><i class=\'bi bi-basket2\'></i></div>';" />
        }
        else
        {
            <div class="product-img-placeholder">
                <i class="bi bi-basket2"></i>
            </div>
        }
    </div>
    <div class="product-card-body">
        <p class="product-category">@Model.Category.Name</p>
        <h6 class="product-name">@Model.NameProduct</h6>
        <p class="product-price">@Model.Price.ToString("F2") €</p>
    </div>
    <div class="product-card-footer">
        <form asp-action="AddToCart" asp-controller="Home" method="get">
            <input type="hidden" name="_articleId" value="@Model.IDArticle" />
            <input type="hidden" name="_quantity" value="1" />
            <button type="submit" class="btn-add-cart w-100">Add to cart</button>
        </form>
    </div>
</div>
